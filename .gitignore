/target

# C++Builder/RAD Studio build outputs
**/Win32/Debug/
**/Win32/Release/
**/Win64/Debug/
**/Win64/Release/

# Object and binary artifacts
*.obj
*.o
*.exe
*.dll
*.map
*.ilc
*.ild
*.ilf
*.ils
*.pch
*.pdi
*.tds
*.#00

# IDE/user-local project files
*.cbproj.local

# RAD Studio local history folders
**/__history/
**/__agent_snapshots/
**/__recovery/

# Stray temp / session artefacts
*_TEMP.txt
TEMP_*.txt
SUMMARIES_TEMP.txt
filtered_transcript.txt
build.log
*.log

# Generated slim (hex-stripped) form shadows for AI context — regenerate with
# scripts/strip-dfm-hex.ps1; never commit. NOTE: *.cbproj / *.groupproj are
# intentionally NOT ignored — managed manually but kept version-controlled;
# they are excluded from AI context via .copilotignore.
.copilot/dfm-slim/

# Keep distributable example executables tracked
!sig-net-example-tid-level-tx/Win32/
!sig-net-example-tid-level-tx/Win32/Debug/
sig-net-example-tid-level-tx/Win32/Debug/*
!sig-net-example-tid-level-tx/Win32/Debug/*.exe
